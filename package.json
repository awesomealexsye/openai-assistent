{
  "name": "ai-meeting-assistant",
  "version": "1.0.0",
  "description": "Real-Time AI Meeting Assistant for macOS",
  "main": "electron/main.js",
  "author": "AI Meeting Assistant Team",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 npx electron .\"",
    "build": "vite build",
    "build:app": "npm run build && electron-builder",
    "start": "npm run build && npx electron .",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "date-fns": "^3.0.6",
    "framer-motion": "^10.18.0",
    "idb": "^8.0.0",
    "lucide-react": "^0.303.0",
    "prismjs": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/prismjs": "^1.26.3",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-vite": "^4.0.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.33",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.aimeetingassistant.app",
    "productName": "AI Meeting Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "AI Meeting Assistant needs access to your microphone to record voice input, transcribe speech, and enable real-time AI conversations.",
        "NSCameraUsageDescription": "AI Meeting Assistant may need camera access for future features.",
        "NSCameraUseContinuityCameraDeviceType": true
      }
    }
  }
}
